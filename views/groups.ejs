<!DOCTYPE html>
<html>
<head><title>Your Groups</title></head>
<body>
  <%- include('partials/header') %>
  <div style="max-width:600px; margin:30px auto;">
    <h2>Your Chats</h2>
    <p>Total groups: <strong><%= groups.length %></strong></p>
    <a href="/groups/create"><button>+ New Group</button></a>
    <hr>
    <% groups.forEach(group => { %>
      <div style="border:1px solid #ccc; padding:10px; margin:10px 0; border-radius:8px;">
        <a href="/messages/<%= group.id %>" style="text-decoration:none;">
          <strong><%= group.name %></strong>
          <span style="float:right; color:#888;">
            <%= group.last_message ? new Date(group.last_message).toLocaleDateString() : 'No messages' %>
          </span>
          <% if (group.unread > 0) { %>
            <span style="background:red; color:white; border-radius:50%; padding:2px 7px; font-size:12px;"><%= group.unread %></span>
          <% } %>
        </a>
      </div>
    <% }) %>
  </div>
</body>
</html>