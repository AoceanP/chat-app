<!DOCTYPE html>
<html>
<head><title>Sign Up</title></head>
<body>
  <%- include('partials/header') %>
  <div style="max-width:400px; margin:50px auto;">
    <h2>Sign Up</h2>
    <% if (error) { %><p style="color:red;"><%= error %></p><% } %>
    <form method="POST" action="/signup">
      <input type="text" name="username" placeholder="Username" required style="display:block; width:100%; margin-bottom:10px; padding:8px;"/>
      <input type="password" name="password" placeholder="Password (10+ chars, upper, lower, number, symbol)" required style="display:block; width:100%; margin-bottom:10px; padding:8px;"/>
      <button type="submit">Sign Up</button>
    </form>
    <p>Already have an account? <a href="/login">Login</a></p>
  </div>
</body>
</html>