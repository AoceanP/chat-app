<!DOCTYPE html>
<html>
<head>
  <title>Sign Up</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <%- include('partials/header') %>
  <div class="container">
    <div class="card">
      <h2>Sign Up</h2>
      <% if (error) { %><p class="error"><%= error %></p><% } %>
      <form method="POST" action="/signup">
        <input type="text" name="username" placeholder="Username" required/>
        <input type="password" name="password" placeholder="Password (10+ chars, upper, lower, number, symbol)" required/>
        <button type="submit" class="btn-full">Sign Up</button>
      </form>
      <p class="text-center text-muted" style="margin-top:16px;">Already have an account? <a href="/login">Login</a></p>
    </div>
  </div>
</body>
</html>