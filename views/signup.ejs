<%#
 * @author Aleksandar Panich
 * @version Assignment02
 *
 * - Renders the signup form for new user registration
 * - Displays validation errors passed from the auth route
 * - Informs users of the password complexity requirements
 *
 * Step 1: Include the shared header partial
 * Step 2: Display error message if one was passed from the route
 * Step 3: Render the signup form with username and password fields
%>
<!DOCTYPE html>
<html>
<head>
  <title>Sign Up</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <%- include('partials/header') %>
  <div class="container">
    <div class="card">
      <h2>Sign Up</h2>
      <% if (error) { %>
        <p class="error"><%= error %></p>
      <% } %>
      <form method="POST" action="/signup">
        <input type="text" name="username" placeholder="Username" required/>
        <input type="password" name="password" placeholder="Password (10+ chars, upper, lower, number, symbol)" required/>
        <button type="submit" class="btn-full">Sign Up</button>
      </form>
      <p class="text-center text-muted" style="margin-top:16px;">
        Already have an account? <a href="/login">Login</a>
      </p>
    </div>
  </div>
</body>
</html>