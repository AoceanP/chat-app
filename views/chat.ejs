<!DOCTYPE html>
<html>
<head>
  <title><%= group.name %></title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <%- include('partials/header') %>
  <div class="container-wide">

    <div class="chat-header">
      <h2><%= group.name %></h2>
      <details class="members-dropdown">
        <summary>👥 Members</summary>
        <div class="members-panel">
          <strong style="font-size:13px; color:#555;">Members:</strong><br><br>
          <% groupMembers.forEach(m => { %>
            <span class="member-tag">👤 <%= m.username %></span>
          <% }) %>
          <hr class="divider">
          <form method="POST" action="/messages/<%= groupId %>/invite">
            <input type="text" name="username" placeholder="Invite by username"/>
            <button type="submit" class="btn-full btn-sm" style="margin-top:4px;">Invite</button>
          </form>
        </div>
      </details>
    </div>

    <div id="chat-box">
      <% if (messages.length === 0) { %>
        <p class="text-center text-muted" style="margin-top:80px;">No messages yet. Say hello! 👋</p>
      <% } %>
      <% messages.forEach((msg, i) => { %>

        <% if (i === firstUnreadIndex) { %>
          <div class="unread-divider">
            <span>New messages</span>
          </div>
        <% } %>

        <div class="<%= msg.username === user.username ? 'msg-wrapper-right' : 'msg-wrapper-left' %>">
          <div class="<%= msg.username === user.username ? 'msg-bubble-right' : 'msg-bubble-left' %>">
            <div class="msg-meta"><%= msg.username %> · <%= new Date(msg.sent_at).toLocaleTimeString([], {hour:'2-digit', minute:'2-digit'}) %></div>
            <div><%= msg.content %></div>
          </div>
          <div class="msg-reactions">
            <% if (msg.reactions) { %>
              <% msg.reactions.split(',').forEach(r => { %>
                <span class="reaction-badge"><%= r.split(':')[0] %></span>
              <% }) %>
            <% } %>
            <form method="POST" action="/messages/<%= groupId %>/react/<%= msg.id %>" class="reaction-form" style="display:inline;">
              <select name="emoji">
                <option>👍</option>
                <option>❤️</option>
              </select>
              <button type="submit">+</button>
            </form>
          </div>
        </div>
      <% }) %>
    </div>

    <form method="POST" action="/messages/<%= groupId %>/send" class="chat-input-row">
      <input type="text" name="content" placeholder="Type a message..." required/>
      <button type="submit">Send</button>
    </form>
  </div>

  <script>
    const chatBox = document.getElementById('chat-box');
    const unreadDivider = document.querySelector('.unread-divider');

    function scrollToBottom() { chatBox.scrollTop = chatBox.scrollHeight; }

    // Scroll to unread divider if it exists, otherwise scroll to bottom
    if (unreadDivider) {
      unreadDivider.scrollIntoView({ block: 'center' });
    } else {
      scrollToBottom();
    }

    setInterval(() => {
      const atBottom = chatBox.scrollHeight - chatBox.scrollTop <= chatBox.clientHeight + 50;
      fetch(window.location.href)
        .then(r => r.text())
        .then(html => {
          const parser = new DOMParser();
          const doc = parser.parseFromString(html, 'text/html');
          const newBox = doc.getElementById('chat-box');
          if (newBox.innerHTML !== chatBox.innerHTML) {
            chatBox.innerHTML = newBox.innerHTML;
            if (atBottom) scrollToBottom();
          }
        });
    }, 3000);
  </script>

</body>
</html>