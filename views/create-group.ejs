<!DOCTYPE html>
<html>
<head>
  <title>Create Group</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <%- include('partials/header') %>
  <div class="container">
    <div class="card">
      <h2>New Group</h2>
      <form method="POST" action="/groups/create">
        <input type="text" name="name" placeholder="Group name" required/>
        <p class="text-muted" style="margin-bottom:8px;">Add members:</p>
        <div class="member-list">
          <% if (users.length === 0) { %>
            <p class="text-muted">No other users yet.</p>
          <% } %>
          <% users.forEach(u => { %>
            <label>
              <input type="checkbox" name="members" value="<%= u.id %>"/> <%= u.username %>
            </label>
          <% }) %>
        </div>
        <button type="submit" class="btn-full">Create Group</button>
      </form>
    </div>
  </div>
</body>
</html>