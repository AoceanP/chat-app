<!DOCTYPE html>
<html>
<head><title>Create Group</title></head>
<body>
  <%- include('partials/header') %>
  <div style="max-width:400px; margin:30px auto;">
    <h2>Create New Group</h2>
    <form method="POST" action="/groups/create">
      <input type="text" name="name" placeholder="Group name" required style="display:block; width:100%; margin-bottom:10px; padding:8px;"/>
      <p>Select members:</p>
      <% users.forEach(u => { %>
        <label>
          <input type="checkbox" name="members" value="<%= u.id %>"/> <%= u.username %>
        </label><br>
      <% }) %>
      <br>
      <button type="submit">Create Group</button>
    </form>
  </div>
</body>
</html>